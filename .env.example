ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MCP Server Paths (update these to match your installations)
YAHOO_FINANCE_MCP_PATH=/path/to/yahoo-finance-mcp
TWITTER_MCP_PATH=/path/to/twitter-mcp
TRADINGVIEW_CHART_MCP_PATH=/path/to/tradingview-chart-mcp

# Twitter API (if using direct Twitter integration)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Optional: Custom trading symbols (comma-separated)
CUSTOM_SYMBOLS=AAPL,GOOGL,MSFT,TSLA,NVDA,SPY,QQQ

